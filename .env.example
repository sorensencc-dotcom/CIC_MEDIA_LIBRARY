# Wayland Configuration — Secrets Management
# Copy to .env and fill in real values before deploying

# Slack webhooks (obtained from Slack workspace settings)
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_MAIN=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_WEBHOOK_ALERTS=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# MCP Server port (optional, defaults to 7010)
MCP_PORT=7010

# Node environment
NODE_ENV=production

# Logging level
LOG_LEVEL=info
