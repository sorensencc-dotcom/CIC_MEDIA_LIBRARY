(
    name: "cic-weekly-ops",
    description: "Weekly ops follow-up + curation + report + notify",
    schedule: "0 9 * * 1",
    timeout_minutes: 120,
    on_failure: "alert_and_continue",
    stages: [
        (
            name: "follow-ops",
            kind: "shell",
            command: "pwsh",
            args: ["scripts/cic-follow-ops.ps1"],
            retry_count: 1,
            timeout_minutes: 60,
            on_failure: "alert",
        ),
        (
            name: "curate",
            kind: "shell",
            command: "pwsh",
            args: ["scripts/curate-cic-marketing-assets.ps1"],
            retry_count: 1,
            timeout_minutes: 30,
            on_failure: "alert",
        ),
        (
            name: "notify-success",
            kind: "channel",
            channel: "slack-main",
            template: "Weekly CIC ops complete: report generated at {{report_path}}.",
            condition: "all_stages_success",
        ),
        (
            name: "notify-failure",
            kind: "channel",
            channel: "slack-alerts",
            template: "Weekly CIC ops FAILED at stage: {{failed_stage}}. Error: {{error_message}}.",
            condition: "any_stage_failure",
        ),
    ],
)
