(
    name: "cic-archive-query",
    description: "Archive query + reconciliation + notify",
    schedule: "0 4 * * 1",
    timeout_minutes: 90,
    on_failure: "alert_and_continue",
    stages: [
        (
            name: "query-archives",
            kind: "shell",
            command: "pwsh",
            args: ["scripts/query-archives.ps1"],
            retry_count: 1,
            timeout_minutes: 45,
            on_failure: "alert",
        ),
        (
            name: "reconcile",
            kind: "shell",
            command: "pwsh",
            args: ["scripts/reconciliation-loop.ps1"],
            retry_count: 2,
            timeout_minutes: 45,
            on_failure: "alert",
        ),
        (
            name: "notify-success",
            kind: "channel",
            channel: "slack-main",
            template: "Archive query complete: {{archive_results.total_records}} records, {{archive_results.gaps}} gaps identified.",
            condition: "all_stages_success",
        ),
        (
            name: "notify-failure",
            kind: "channel",
            channel: "slack-alerts",
            template: "Archive query FAILED at stage: {{failed_stage}}. Error: {{error_message}}.",
            condition: "any_stage_failure",
        ),
    ],
)
